---
interface Props {
	background?: 'white' | 'gray' | 'green' | 'gray-50' | 'tuhura-gray';
	padding?: 'sm' | 'md' | 'lg';
	class?: string;
}

const { background = 'white', padding = 'md', class: className = '' } = Astro.props;

const backgroundClasses = {
	white: 'bg-white dark:bg-slate-950',
	gray: 'bg-gray-50 dark:bg-slate-900',
	'gray-50': 'bg-gray-50 dark:bg-slate-900',
	green: 'bg-tuhura-green',
	'tuhura-gray': 'bg-tuhura-gray dark:bg-slate-900',
};

const paddingClasses = {
	sm: 'py-12',
	md: 'py-20',
	lg: 'py-28',
};
---

<section class={`${backgroundClasses[background]} ${paddingClasses[padding]} ${className}`}>
	<div class="container-custom">
		<slot />
	</div>
</section>
